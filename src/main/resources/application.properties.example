spring.application.name=ms-community
server.port=8084

spring.datasource.url=jdbc:postgresql://localhost:5432/portalcomunitario
spring.datasource.username=postgres
spring.datasource.password=CAMBIAR_PASSWORD
spring.datasource.driver-class-name=org.postgresql.Driver

spring.jpa.hibernate.ddl-auto=validate
spring.jpa.show-sql=true
spring.jpa.open-in-view=false

spring.flyway.enabled=true
spring.flyway.baseline-on-migrate=true
# Baseline en 0 para que V1 sí se aplique.
spring.flyway.baseline-version=0
# Tabla de historial propia (el schema public se comparte con ms-auth).
spring.flyway.table=flyway_schema_history_community

# DEBE coincidir EXACTO con el app.jwt.secret de ms-auth (firma HS512).
app.jwt.secret=CAMBIAR_JWT_SECRET_HS512
app.jwt.expiration=86400000

# RabbitMQ (mensajería). En Docker Compose, host=rabbitmq
spring.rabbitmq.host=localhost
spring.rabbitmq.port=5672
spring.rabbitmq.username=guest
spring.rabbitmq.password=guest
# El broker es opcional en dev; no debe tumbar el health check.
management.health.rabbit.enabled=false

# Llamadas internas a ms-auth (resolver contacto/consentimiento de destinatarios)
app.auth.base-url=http://localhost:8081
app.internal.token=portal-internal-2026
